<%= form_with model: @event do |f| %>
    <div>
        <%= f.label :name, "イベント名" %>
        <%= f.text_field :name %>
    </div>

    <div>
    <%= f.label :date %>
    <%= f.date_field :date %>
  </div>

  <div>
    <%= f.label :location %>
    <%= f.text_field :location %>
  </div>

  <%= f.submit "イベント作成" %>

<% end %>